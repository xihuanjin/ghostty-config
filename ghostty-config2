# ===== 字体设置 =====
# 使用 Nerd Font（图标字体），需要先安装
font-family = "JetBrainsMono Nerd Font"
font-family = "Menlo"
font-size = 14

# 字体特性
font-feature = -calt
font-feature = +liga
font-feature = +dlig

# ===== 窗口外观 =====
# 窗口大小
window-width = 120
window-height = 36
window-padding-x = 12
window-padding-y = 8

# 圆角
window-corner-radius = 8

# 标题栏
titlebar-style = transparent
window-decoration = buttonless

# ===== 主题配色 =====
# 内置主题可选: catppuccin-latte, catppuccin-mocha, dracula, gruvbox, solarized, tokyo-night
theme = catppuccin-mocha
# 浅色主题
# theme = catppuccin-latte

# ===== 背景 =====
background = #1e1e2e
background-blur-radius = 20
background-opacity = 0.9

# ===== 光标 =====
cursor-style = bar
cursor-style-blink = false
cursor-color = #f5e0dc

# ===== 性能 =====
# 硬件加速
# macOS 启用 Metal
gpu-acceleration = auto

# ===== 滚动 =====
mouse-scroll-multiplier = 3
scrollback-limit = 10000

# ===== 复制粘贴 =====
copy-on-select = true

# ===== 快捷键 =====
# 切换主题
keybind = global:cmd+shift+t=toggle_split_zoom
keybind = cmd+t=new_split:right
keybind = cmd+shift+enter=toggle_fullscreen
keybind = cmd+k=clear_screen

# 复制粘贴
keybind = cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard

# 分屏切换
keybind = cmd+alt+arrow_left=goto_split:left
keybind = cmd+alt+arrow_right=goto_split:right
keybind = cmd+alt+arrow_up=goto_split:up
keybind = cmd+alt+arrow_down=goto_split:down

# 调整分屏大小
keybind = cmd+shift+arrow_left=resize_split:left,2
keybind = cmd+shift+arrow_right=resize_split:right,2
keybind = cmd+shift+arrow_up=resize_split:up,2
keybind = cmd+shift+arrow_down=resize_split:down,2

# ===== Shell 集成 =====
shell-integration = zsh
shell-integration-features = cursor,sudo,title
